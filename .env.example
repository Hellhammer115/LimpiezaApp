# Copy to .env and fill in. NEVER commit .env.
# Only EXPO_PUBLIC_* values ship inside the app bundle — they are safe to
# expose BECAUSE every table is protected by Row Level Security.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: set to 1 to preview the UI with bundled sample data and no
# backend (auth/checkout inert). Never set in production builds.
# EXPO_PUBLIC_DEMO=1

# --- Edge Function secrets (set with `supabase secrets set`, NOT in .env) ---
# supabase secrets set MP_ACCESS_TOKEN=APP_USR-...   (Mercado Pago access token)
# supabase secrets set MP_WEBHOOK_SECRET=...         (Mercado Pago webhook signing secret)
